# ConnectWise credentials for LOCAL / stdio development.
# In hosted (HTTP) mode these are supplied per request as X-CW-* headers instead.

CW_COMPANY_ID=your_company_id
CW_PUBLIC_KEY=your_public_key
CW_PRIVATE_KEY=your_private_key
CW_CLIENT_ID=your_client_id_guid     # required by CW on every API call
CW_REGION=na                         # na | eu | au | aus | za
# CW_HOST=cw.example.com             # set instead of CW_REGION for self-hosted

# Server runtime
# CW_MCP_TRANSPORT=stdio             # default: http
# CW_MCP_HOST=127.0.0.1
# CW_MCP_PORT=8000
# CW_DEFAULT_PAGE_SIZE=25
